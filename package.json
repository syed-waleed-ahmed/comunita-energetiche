{
  "name": "comunita-energetiche-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @ce/apps-api dev",
    "studio": "pnpm --filter @ce/packages-mastra studio",
    "agent:chat": "npx tsx packages/mastra/src/cli.ts",
    "test": "cd packages/core && npx jest --verbose",
    "seed": "npx tsx scripts/seed.ts",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:generate": "npx prisma generate",
    "prisma:studio": "npx prisma studio"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@mastra/memory": "^1.5.2",
    "@mastra/pg": "^1.7.0",
    "@prisma/client": "^5.22.0",
    "json2csv": "6.0.0-alpha.2",
    "mastra": "^1.3.5",
    "prisma": "^5.22.0"
  }
}