# ─── Comunità Energetiche — Environment Variables ───

# Database (PostgreSQL / Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Supabase Storage (optional, for document file storage)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# API Authentication
default_x_api_key=changeme-dev-key

# CSV delimiter for Tracciato generation
CSV_DELIMITER=;

# ─── LLM Keys (set at least one for the Mastra Agent) ───
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
