# ──────────────────────────────────────────────
# Comunità Energetiche — Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database (PostgreSQL / Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/comunita_energetiche

# Supabase Storage (optional, for document file storage in production)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# API Authentication
API_KEY=changeme-dev-key

# CSV delimiter for Tracciato generation
CSV_DELIMITER=;

# File Storage Paths (relative to project root)
UPLOAD_DIR=uploads
TRACCIATO_DIR=tracciato

# ─── LLM Keys (set at least one for the Mastra Agent) ───
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
