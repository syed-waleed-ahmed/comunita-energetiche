// Prisma schema for Comunità Energetiche MVP
// Domain model covering members, documents, extractions, validation, and tracciato

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  status       String   @default("DRAFT") // DRAFT | VALIDATION_ERROR | READY_FOR_TRACCIATO | PENDING | GENERATED
  memberType   String?  // CONSUMER | PRODUCER | PROSUMER

  // ── Identity (Anagrafica) ──
  name         String?
  surname      String?
  fiscalCode   String?  @unique
  vatNumber    String?  @unique
  legalType    String?  // PF (persona fisica) | PG (persona giuridica)
  subjectType  String?  // AI | PI | AS

  // ── Birth Data ──
  placeOfBirth    String?
  provinceOfBirth String?
  countryOfBirth  String?
  dateOfBirth     DateTime?
  gender          String?   // M | F

  // ── Address ──
  address      String?
  houseNumber  String?
  city         String?
  province     String?
  postalCode   String?

  // ── Contacts ──
  phone        String?
  mobile       String?
  email        String?  @unique

  // ── Professional & Financial ──
  profession   String?
  iban         String?
  podCode      String?  @unique
  referent     String?   // Referente Part Energy
  conventions  Json?     // e.g. { "banca360": true, "otherAssoc": "XYZ" }

  // ── Consent Tracking ──
  consentPrivacy    Boolean @default(false)
  consentStatute    Boolean @default(false)
  consentRegulation Boolean @default(false)

  // ── Producer-specific fields ──
  censimpCode        String?  // CENSIMP code from GAUDÌ certificate
  plantPowerKW       Float?   // Declared plant power (kW) from GAUDÌ
  installedCapacityKW Float?  // Installed PV capacity (kW) from nameplates
  hasStorage         Boolean? // Whether installation includes battery storage
  dataAttivazione    String?  // Plant activation date (DD/MM/YYYY) for GSE

  // ── GSE Tracciato / Company fields ──
  formaGiuridica     String?  // Legal form (SRL, SPA, etc.) from Visura
  codiceAteco        String?  // ATECO activity code (format: XX.XX.XX)
  ragioneSociale     String?  // Company name / business name from Visura
  accumuloStandalone String?  // Standalone battery storage indicator (SI/NO)
  sottoTipologiaAmministrazioneLocale String? // Sub-type per ISTAT (required if subjectType=AI)
  studioAssociatoSocietaProfessionisti String? // Associated professional studio name

  // ── Relations ──
  documents    Document[]
  validationIssues ValidationIssue[]
  tracciatoRows TracciatoRow[]

  // ── Indexes ──
  @@index([status])
  @@index([memberType])
}

model Document {
  id           String   @id @default(uuid())
  memberId     String
  docType      String   // ID | BILL | VISURA | PAYMENT | GAUDI_CERT | etc.
  storagePath  String
  mimeType     String
  uploadedAt   DateTime @default(now())
  extractionStatus String @default("PENDING") // PENDING | DONE | NOT_EXTRACTABLE
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  extractionResults ExtractionResult[]

  @@index([memberId])
  @@index([docType])
}

model ExtractionResult {
  id           String   @id @default(uuid())
  documentId   String
  schemaName   String
  json         Json
  confidence   Float?
  evidence     Json?
  createdAt    DateTime @default(now())
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model ValidationIssue {
  id           String   @id @default(uuid())
  memberId     String
  severity     String   // ERROR | WARN | INFO
  code         String
  message      String
  field        String?
  source       String   // RULE_ENGINE | CROSS_VALIDATION
  createdAt    DateTime @default(now())
  resolvedAt   DateTime?
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([severity])
}

model TracciatoBatch {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  createdBy    String?
  status       String   @default("PENDING") // PENDING | GENERATED
  rowCount     Int
  ruleVersion  String?
  templateVersion String?
  rows         TracciatoRow[]
  fileArtifacts FileArtifact[]
}

model TracciatoRow {
  id           String   @id @default(uuid())
  batchId      String
  memberId     String
  podCode      String?
  dataJson     Json
  isValid      Boolean
  errorsJson   Json?
  batch        TracciatoBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  member       Member         @relation(fields: [memberId], references: [id])

  @@index([batchId])
  @@index([memberId])
}

model FileArtifact {
  id           String   @id @default(uuid())
  batchId      String
  type         String   // CSV | PDF
  storagePath  String
  createdAt    DateTime @default(now())
  batch        TracciatoBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
}

model RequiredDocConfig {
  id           String   @id @default(uuid())
  docType      String   @unique
  required     Boolean
  createdAt    DateTime @default(now())
}
