// Initial Prisma schema for MVP domain model
// Save as schema.prisma in prisma/

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  status       String
  memberType   String?  // CONSUMER, PRODUCER, or PROSUMER

  // ── Identity (Anagrafica) ──
  name         String?
  surname      String?
  fiscalCode   String?
  vatNumber    String?
  legalType    String?  // PF (persona fisica) / PG (persona giuridica)
  subjectType  String?  // AI/PI/AS/…

  // ── Birth Data ──
  placeOfBirth    String?
  provinceOfBirth String?
  countryOfBirth  String?
  dateOfBirth     DateTime?
  gender          String?   // M or F

  // ── Address ──
  address      String?
  houseNumber  String?
  city         String?
  province     String?
  postalCode   String?

  // ── Contacts ──
  phone        String?
  mobile       String?
  email        String?

  // ── Professional & Financial ──
  profession   String?
  iban         String?
  podCode      String?
  referent     String?   // Referente Part Energy
  conventions  Json?     // e.g. { "banca360": true, "otherAssoc": "XYZ" }

  // ── Consent Tracking ──
  consentPrivacy    Boolean @default(false)
  consentStatute    Boolean @default(false)
  consentRegulation Boolean @default(false)

  // ── Producer-specific fields ──
  censimpCode        String?  // CENSIMP code from GAUDÌ certificate
  plantPowerKW       Float?   // Declared plant power (kW) from GAUDÌ
  installedCapacityKW Float?  // Installed PV capacity (kW) from nameplates
  hasStorage         Boolean? // Whether installation includes battery storage

  // ── Relations ──
  documents    Document[]
  validationIssues ValidationIssue[]
  tracciatoRows TracciatoRow[]
}

model Document {
  id           String   @id @default(uuid())
  memberId     String
  docType      String
  storagePath  String
  mimeType     String
  uploadedAt   DateTime @default(now())
  extractionStatus String
  member       Member   @relation(fields: [memberId], references: [id])
  extractionResults ExtractionResult[]
}

model ExtractionResult {
  id           String   @id @default(uuid())
  documentId   String
  schemaName   String
  json         Json
  confidence   Float?
  evidence     Json?
  createdAt    DateTime @default(now())
  document     Document @relation(fields: [documentId], references: [id])
}

model ValidationIssue {
  id           String   @id @default(uuid())
  memberId     String
  severity     String
  code         String
  message      String
  field        String?
  source       String
  createdAt    DateTime @default(now())
  resolvedAt   DateTime?
  member       Member   @relation(fields: [memberId], references: [id])
}

model TracciatoBatch {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  createdBy    String?
  status       String
  rowCount     Int
  ruleVersion  String?
  templateVersion String?
  rows         TracciatoRow[]
  fileArtifacts FileArtifact[]
}

model TracciatoRow {
  id           String   @id @default(uuid())
  batchId      String
  memberId     String
  podCode      String?
  dataJson     Json
  isValid      Boolean
  errorsJson   Json?
  batch        TracciatoBatch @relation(fields: [batchId], references: [id])
  member       Member         @relation(fields: [memberId], references: [id])
}

model FileArtifact {
  id           String   @id @default(uuid())
  batchId      String
  type         String
  storagePath  String
  createdAt    DateTime @default(now())
  batch        TracciatoBatch @relation(fields: [batchId], references: [id])
}

model RequiredDocConfig {
  id           String   @id @default(uuid())
  docType      String
  required     Boolean
  createdAt    DateTime @default(now())
}
